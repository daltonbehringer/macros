{
  "name": "macros",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @macros/db db:generate",
    "db:migrate": "pnpm --filter @macros/db db:migrate",
    "db:push": "pnpm --filter @macros/db db:push",
    "db:studio": "pnpm --filter @macros/db db:studio"
  },
  "devDependencies": {
    "turbo": "^2.2.3",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowAny": ["@opentelemetry/api"]
    }
  }
}
